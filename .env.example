# Canonical env reference. Copy relevant vars to web/.env.local and api/.env.

# --- Supabase (both services) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Web -> API ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# --- API ---
API_CORS_ORIGINS=http://localhost:3000

# --- Phase 4 (voice + agent) ---
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=

# --- STT Engine ---
# STT_ENGINE=auto                # local | openai | auto
# FASTER_WHISPER_MODEL=large-v3  # tiny | base | small | medium | large-v3
# FASTER_WHISPER_DEVICE=cpu      # cpu | cuda
# FASTER_WHISPER_COMPUTE=int8    # int8 | float16 | float32

# --- LangSmith Observability ---
# Get your API key free at https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxx
# LANGSMITH_PROJECT=bankbot-vision
